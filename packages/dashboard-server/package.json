{
  "name": "@org-roam-toolkit/dashboard-server",
  "version": "0.1.0",
  "description": "Local HTTP server + Svelte UI for the org-roam-toolkit observability dashboard",
  "license": "MIT",
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "ortk-dashboard": "./bin/dashboard-serve"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "ui/dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:ui": "vite build --config ui/vite.config.ts",
    "build:all": "npm run build && npm run build:ui",
    "start": "node dist/server.js",
    "dev:ui": "vite --config ui/vite.config.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@org-roam-toolkit/emacs": "*",
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0"
  },
  "devDependencies": {
    "svelte": "^5.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
